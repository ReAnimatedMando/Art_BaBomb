@model List<Art_BaBomb.Web.Models.ViewModels.UserRoleViewModel>

@{
    ViewData["Title"] = "User Manager";
    var availableRoles = ViewBag.AvailableRoles as List<string> ?? new List<string>();
}

<section class="form-hero page-gap">
    <div>
        <div class="eyebrow">Admin Tools</div>
        <h1 class="form-hero-title">User Manager</h1>
        <p class="form-hero-subtitle">
            Manage user access and assign roles for the Art Ba-Bomb workspace.
        </p>
    </div>
</section>

<div class="page-alert-stack">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
</div>

<div class="project-index-card">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0 project-index-table">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Current Role</th>
                    <th style="width: 300px;">Assign Role</th>
                    <th class="text-end" style="width: 120px;">Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-semibold">@user.Email</td>

                        <td>
                            <span class="badge @(user.CurrentRole == "Admin" ? "bg-primary" : "bg-warning text-dark") fs-6">
                                @user.CurrentRole
                            </span>
                        </td>

                        <td>
                            <form asp-action="UpdateRole" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="UserId" value="@user.UserId" />
                                <input type="hidden" name="Email" value="@user.Email" />
                                <input type="hidden" name="CurrentRole" value="@user.CurrentRole" />

                                <select name="SelectedRole" class="form-select form-select-sm">
                                    @foreach (var role in availableRoles)
                                    {
                                        if (role == user.CurrentRole)
                                        {
                                            <option value="@role" selected="selected">@role</option>
                                        }
                                        else
                                        {
                                            <option value="@role">@role</option>
                                        }
                                    }
                                </select>

                                <button type="submit" class="btn btn-sm btn-art-primary">
                                    Save
                                </button>
                            </form>
                        </td>

                        <td class="text-end">
                            @if (!string.Equals(user.Email, User.Identity?.Name, StringComparison.OrdinalIgnoreCase))
                            {
                                <form asp-action="DeleteUser" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete @user.Email? This cannot be undone.');">
                                        Delete
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">Current user</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>