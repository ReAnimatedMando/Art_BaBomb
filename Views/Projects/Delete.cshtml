@using Art_BaBomb.Web.Models;
@model Art_BaBomb.Web.Models.Project

@{
    ViewData["Title"] = "Delete Project";
}

<section class="form-hero mb-4">
    <div>
        <div class="eyebrow text-danger">Danger Zone</div>

        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="form-hero-title mb-0">Delete Project</h1>

            <span class="badge @(Model.Department == ProjectDepartment.SetDec ? "bg-primary" : "bg-warning text-dark") fs-6">
                @(Model.Department == ProjectDepartment.SetDec ? "Set Dec" : "Props")
            </span>
        </div>

        <p class="form-hero-subtitle">
            You are about to permanently delete <strong>@Model.Name</strong>.
        </p>
    </div>
</section>

<div class="form-shell">

    <section class="form-section-card border-danger-subtle">
        <h2 class="text-danger">Confirm Deletion</h2>

        <div class="alert alert-danger">
            ⚠ This action cannot be undone. All items associated with this project will be deleted.
        </div>

        <dl class="row mb-4 item-detail-list">

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)
            </dd>

            <dt class="col-sm-3">Budget</dt>
            <dd class="col-sm-9">@Model.Budget.ToString("C")</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>

        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="form-actions">
                <button type="submit" class="btn btn-danger">
                    Delete Project
                </button>

                <a asp-action="Index" class="btn btn-art-outline">
                    Cancel
                </a>
            </div>
        </form>

    </section>

</div>