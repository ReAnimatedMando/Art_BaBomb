@using Art_BaBomb.Web.Models;
@model IEnumerable<Art_BaBomb.Web.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<section class="project-index-hero mb-4">
    <div>
        <div class="eyebrow">Production Workspace</div>
        <h1 class="project-index-title">Projects</h1>
        <p class="project-index-subtitle">
            Open active Set Dec and Props projects, review department scope, and keep buying workflows coordinated.
        </p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-art-primary">
            Create Project
        </a>
    }
</section>

<section class="project-index-toolbar mb-4">
    <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center flex-wrap">
        <label for="department" class="form-label mb-0 fw-semibold">Department</label>

        <select name="department" id="department" class="form-select project-filter-select">
            <option value="">All Departments</option>
            <option value="SetDec" selected="@(ViewData["SelectedDepartment"]?.ToString() == "SetDec")">Set Dec</option>
            <option value="Props" selected="@(ViewData["SelectedDepartment"]?.ToString() == "Props")">Props</option>
        </select>

        <button type="submit" class="btn btn-art-outline">
            Apply
        </button>

        <a asp-action="Index" class="btn btn-art-outline">
            Clear
        </a>
    </form>
</section>

<div class="project-index-card">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0 project-index-table">
            <thead>
                <tr>
                    <th>Project</th>
                    <th class="text-center">Department</th>
                    <th>Description</th>
                    <th>Budget</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.Name</div>
                        </td>

                        <td class="text-center">
                            <span class="badge @(item.Department == ProjectDepartment.SetDec ? "bg-primary" : "bg-warning text-dark") fs-6">
                                @(item.Department == ProjectDepartment.SetDec ? "Set Dec" : "Props")
                            </span>
                        </td>

                        <td class="project-index-description">
                            @(string.IsNullOrWhiteSpace(item.Description) ? "—" : item.Description)
                        </td>

                        <td>
                            @item.Budget.ToString("C")
                        </td>

                        <td>
                            @item.CreatedAt.ToLocalTime().ToString("g")
                        </td>

                        <td>
                            <div class="d-flex justify-content-end gap-2 flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-art-primary">
                                    Open
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-art-outline">
                                        Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
