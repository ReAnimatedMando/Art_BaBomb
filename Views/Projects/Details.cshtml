@model Art_BaBomb.Web.Models.Project

@{
    ViewData["Title"] = "Project Details";

    var neededItems = Model.Items
        .Where(i => string.IsNullOrWhiteSpace(i.Status)
            || i.Status.Trim().Equals("Needed", StringComparison.OrdinalIgnoreCase))
        .OrderBy(i => i.Name)
        .ToList();

    var acquiredItems = Model.Items
        .Where(i =>
            (i.Status ?? "").Trim().Equals("Acquired", StringComparison.OrdinalIgnoreCase)
            && !i.IsReturnRequired
            && !i.IsReturned)
        .OrderBy(i => i.Name)
        .ToList();

    var returnItems = Model.Items
        .Where(i => i.IsReturnRequired && !i.IsReturned)
        .OrderBy(i => i.ReturnByDate)
        .ThenBy(i => i.Name)
        .ToList();

    var returnedItems = Model.Items
        .Where(i => i.IsReturned)
        .OrderByDescending(i => i.ReturnedAt)
        .ThenBy(i => i.Name)
        .ToList();

    var totalEstimated = Model.Items.Sum(i => i.EstimatedCost ?? 0);
    var totalActual = Model.Items.Sum(i => i.ActualCost ?? 0);
    var remainingBudget = Model.Budget - totalActual;

    bool IsImageReceipt(string? path) =>
        !string.IsNullOrWhiteSpace(path) &&
        (path.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<h1>@Model.Name</h1>

<div class="mb-4">
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("g")</p>
</div>

<!-- 🔷 Budget Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Budget</h6>
                <div class="fw-bold text-end">
                    @Model.Budget.ToString("C")
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Estimated</h6>
                <div class="fw-bold text-end">
                    @totalEstimated.ToString("C")
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Actual</h6>
                <div class="fw-bold text-end">
                    @totalActual.ToString("C")
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm @(remainingBudget < 0 ? "border-danger" : "")">
            <div class="card-body">
                <h6 class="text-muted">Remaining</h6>
                <div class="fw-bold text-end @(remainingBudget < 0 ? "text-danger" : "")">
                    @remainingBudget.ToString("C")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <a asp-controller="Items"
       asp-action="Create"
       asp-route-projectId="@Model.Id"
       class="btn btn-primary">
        + Add Item
    </a>

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        Edit Project
    </a>

    <a asp-action="Index" class="btn btn-outline-dark">
        Back to Projects
    </a>
</div>

<hr />

<!-- ===================== NEEDED ===================== -->
<h2>Needed Items (@neededItems.Count)</h2>
@if (neededItems.Any())
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Qty</th>
                <th>Category</th>
                <th>Est.</th>
                <th>Actual</th>
                <th>Receipt</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in neededItems)
        {
            <tr>
                <td>
                    <div class="d-flex align-items-start gap-2">
                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl"
                                 alt="@item.Name"
                                 style="width: 48px; height: 48px; object-fit: cover;"
                                 class="rounded border" />
                        }

                        <div>
                            <div>@item.Name</div>

                            <div class="mt-1">
                                @if (item.IsReturnRequired && !item.IsReturned)
                                {
                                    <span class="badge bg-warning text-dark me-1">Return</span>
                                }

                                @if (item.IsReturned)
                                {
                                    <span class="badge bg-danger me-1">Returned</span>
                                }
                            </div>
                        </div>
                    </div>
                </td>

                <td class="text-center">
                    <div class="d-flex align-items-center gap-1 border rounded px-1 py-1">
                        <form asp-controller="Items" asp-action="AdjustQuantity" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="delta" value="-1" />
                            <button type="submit" class="btn btn-sm btn-link text-decoration-none px-1 py-0">-</button>
                        </form>

                        <span class="fw-semibold text-center" style="min-width: 2rem;">@item.Quantity</span>

                        <form asp-controller="Items" asp-action="AdjustQuantity" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="delta" value="1" />
                            <button type="submit" class="btn btn-sm btn-link text-decoration-none px-1 py-0">+</button>
                        </form>
                    </div>
                </td>
                <td>@item.Category</td>
                <td class="text-end text-nowrap">@item.EstimatedCost?.ToString("C")</td>
                <td class="text-end text-nowrap">@item.ActualCost?.ToString("C")</td>

                <td>
                    @if (IsImageReceipt(item.PurchaseReceiptPath))
                    {
                        <a href="#"
                            data-bs-toggle="modal"
                            data-bs-target="#receiptPreviewModal"
                            data-receipt-src="@item.PurchaseReceiptPath"
                            data-receipt-title="@item.Name - Receipt"
                            class="receipt-preview-trigger">
                                <img src="@item.PurchaseReceiptPath"
                                    alt="Receipt"
                                    style="width: 48px; height: 48px; object-fit: cover;"
                                    class="rounded border" />
                        </a>
                    }
                    else if (!string.IsNullOrWhiteSpace(item.PurchaseReceiptPath))
                    {
                        <a href="@item.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary">
                            Receipt
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>

                <td>
                    <div class="d-flex flex-wrap gap-1">
                        <form asp-controller="Items" asp-action="MarkAcquired" asp-route-id="@item.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success">
                                +
                            </button>
                        </form>

                        <a asp-controller="Items" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No needed items yet.</p>
}

