@model Art_BaBomb.Web.Models.Project

@{
    ViewData["Title"] = "Project Details";

    var neededItems = Model.Items
        .Where(i => string.IsNullOrWhiteSpace(i.Status)
            || i.Status.Trim().Equals("Needed", StringComparison.OrdinalIgnoreCase))
        .OrderBy(i => i.ItemNumber)
        .ToList();

    var acquiredItems = Model.Items
        .Where(i => (i.Status ?? "").Trim().Equals("Acquired", StringComparison.OrdinalIgnoreCase) && !i.IsReturned)
        .OrderBy(i => i.ItemNumber)
        .ToList();

    var returnItems = Model.Items
        .Where(i => i.IsReturnRequired && !i.IsReturned)
        .OrderBy(i => i.ReturnByDate)
        .ThenBy(i => i.ItemNumber)
        .ToList();

    var returnedItems = Model.Items
        .Where(i => i.IsReturned)
        .OrderByDescending(i => i.ReturnedAt)
        .ThenBy(i => i.ItemNumber)
        .ToList();

    var totalEstimated = Model.Items.Sum(i => i.EstimatedCost ?? 0);
    var totalActual = Model.Items.Sum(i => i.ActualCost ?? 0);
    var remainingBudget = Model.Budget - totalActual;

    bool IsImageReceipt(string? path) =>
        !string.IsNullOrWhiteSpace(path) &&
        (path.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<h1>@Model.Name</h1>

<div class="mb-4">
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("g")</p>
</div>

<!-- 🔷 Budget Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Budget</h6>
                <div class="fw-bold">@Model.Budget.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Estimated</h6>
                <div class="fw-bold">@totalEstimated.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Actual</h6>
                <div class="fw-bold">@totalActual.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm @(remainingBudget < 0 ? "border-danger" : "")">
            <div class="card-body">
                <h6 class="text-muted">Remaining</h6>
                <div class="fw-bold @(remainingBudget < 0 ? "text-danger" : "")">
                    @remainingBudget.ToString("C")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <a asp-controller="Items"
       asp-action="Create"
       asp-route-projectId="@Model.Id"
       class="btn btn-primary">
        + Add Item
    </a>

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        Edit Project
    </a>

    <a asp-action="Index" class="btn btn-outline-dark">
        Back to Projects
    </a>
</div>

<hr />

<!-- ===================== NEEDED ===================== -->
<h2>Needed Items (@neededItems.Count)</h2>
@if (neededItems.Any())
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Item #</th>
                <th>Name</th>
                <th>Category</th>
                <th>Est.</th>
                <th>Actual</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in neededItems)
        {
            <tr>
                <td>@item.ItemNumber</td>

                <td>
                    <div class="d-flex align-items-start gap-2">
                        @if (IsImageReceipt(item.PurchaseReceiptPath))
                        {
                            <a href="@item.PurchaseReceiptPath" target="_blank">
                                <img src="@item.PurchaseReceiptPath"
                                    alt="Receipt"
                                    style="width: 42px; height: 42px; object-fit: cover;"
                                    class="rounded border" />
                            </a>
                        }

                        <div>
                            <div>@item.Name</div>

                            <div class="mt-1">
                                @if (!string.IsNullOrWhiteSpace(item.PurchaseReceiptPath) && !IsImageReceipt(item.PurchaseReceiptPath))
                                {
                                    <a href="@item.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary me-1">
                                        Receipt
                                    </a>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.PurchaseReceiptPath))
                                {
                                    <span class="badge bg-info text-dark me-1">Receipt</span>
                                }

                                @if (item.IsReturnRequired && !item.IsReturned)
                                {
                                    <span class="badge bg-warning text-dark me-1">Return</span>
                                }

                                @if (item.IsReturned)
                                {
                                    <span class="badge bg-danger me-1">Returned</span>
                                }
                            </div>
                        </div>
                    </div>
                </td>

                <td>@item.Category</td>
                <td>@item.EstimatedCost?.ToString("C")</td>
                <td>@item.ActualCost?.ToString("C")</td>

                <td>
                    <a asp-controller="Items" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No needed items yet.</p>
}

<!-- ===================== ACQUIRED ===================== -->
<h2>Acquired Items (@acquiredItems.Count)</h2>
@if (acquiredItems.Any())
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Item #</th>
                <th>Name</th>
                <th>Category</th>
                <th>Est.</th>
                <th>Actual</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in acquiredItems)
        {
            <tr>
                <td>@item.ItemNumber</td>

                <td>
                    <div class="d-flex align-items-start gap-2">
                        @if (IsImageReceipt(item.PurchaseReceiptPath))
                        {
                            <a href="@item.PurchaseReceiptPath" target="_blank">
                                <img src="@item.PurchaseReceiptPath"
                                    alt="Receipt"
                                    style="width: 42px; height: 42px; object-fit: cover;"
                                    class="rounded border" />
                            </a>
                        }

                        <div>
                            <div>@item.Name</div>

                            <div class="mt-1">
                                @if (!string.IsNullOrWhiteSpace(item.PurchaseReceiptPath) && !IsImageReceipt(item.PurchaseReceiptPath))
                                {
                                    <a href="@item.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary me-1">
                                        Receipt
                                    </a>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.PurchaseReceiptPath))
                                {
                                    <span class="badge bg-info text-dark me-1">Receipt</span>
                                }

                                @if (item.IsReturnRequired && !item.IsReturned)
                                {
                                    <span class="badge bg-warning text-dark me-1">Return</span>
                                }

                                @if (item.IsReturned)
                                {
                                    <span class="badge bg-danger me-1">Returned</span>
                                }
                            </div>
                        </div>
                    </div>
                </td>

                <td>@item.Category</td>
                <td>@item.EstimatedCost?.ToString("C")</td>
                <td>@item.ActualCost?.ToString("C")</td>

                <td>
                    <a asp-controller="Items" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No acquired items yet.</p>
}

<!-- ===================== RETURN QUEUE ===================== -->
<h2>Return Queue (@returnItems.Count)</h2>
@if (returnItems.Any())
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Item #</th>
                <th>Name</th>
                <th>Category</th>
                <th>Return Location</th>
                <th>Return By</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in returnItems)
        {
            <tr>
                <td>@item.ItemNumber</td>

                <td>
                    <div class="d-flex align-items-start gap-2">
                        @if (IsImageReceipt(item.ReturnReceiptPath))
                        {
                            <a href="@item.ReturnReceiptPath" target="_blank">
                                <img src="@item.ReturnReceiptPath"
                                    alt="Return Receipt"
                                    style="width: 42px; height: 42px; object-fit: cover;"
                                    class="rounded border" />
                            </a>
                        }

                        <div>
                            <div>@item.Name</div>

                            <div class="mt-1">
                                @if (!string.IsNullOrWhiteSpace(item.ReturnReceiptPath) && !IsImageReceipt(item.ReturnReceiptPath))
                                {
                                    <a href="@item.ReturnReceiptPath" target="_blank" class="btn btn-sm btn-outline-danger me-1">
                                        Receipt
                                    </a>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.ReturnReceiptPath))
                                {
                                    <span class="badge bg-info text-dark me-1">Receipt</span>
                                }
                            </div>
                        </div>
                    </div>
                </td>

                <td>@item.Category</td>
                <td>@item.ReturnLocation</td>
                <td>@item.ReturnByDate?.ToString("d")</td>

                <td>
                    <a asp-controller="Items" asp-action="ReturnInfo" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                        Return Info
                    </a>

                    <form asp-controller="Items" asp-action="MarkReturned" asp-route-id="@item.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Mark Returned</button>
                    </form>

                    <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                        Details
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No items in the return queue.</p>
}

<!-- ===================== RETURNED ITEMS ===================== -->
<h2>Returned Items (@returnedItems.Count)</h2>
@if (returnedItems.Any())
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Item #</th>
                <th>Name</th>
                <th>Category</th>
                <th>Returned At</th>
                <th>Receipt Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in returnedItems)
        {
            <tr>
                <td>@item.ItemNumber</td>

                <td>
                    <div class="d-flex align-items-start gap-2">
                        @if (IsImageReceipt(item.ReturnReceiptPath))
                        {
                            <a href="@item.ReturnReceiptPath" target="_blank">
                                <img src="@item.ReturnReceiptPath"
                                     alt="Return Receipt"
                                     style="width: 42px; height: 42px; object-fit: cover;"
                                     class="rounded border" />
                            </a>
                        }

                        <div>
                            <div>@item.Name</div>

                            <div class="mt-1">
                                <span class="badge bg-danger me-1">Returned</span>

                                @if (!string.IsNullOrWhiteSpace(item.ReturnReceiptPath))
                                {
                                    <span class="badge bg-success me-1">Receipt Uploaded</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark me-1">Missing Receipt</span>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.ReturnReceiptPath) && !IsImageReceipt(item.ReturnReceiptPath))
                                {
                                    <a href="@item.ReturnReceiptPath" target="_blank" class="btn btn-sm btn-outline-danger me-1">
                                        Receipt
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </td>

                <td>@item.Category</td>
                <td>@item.ReturnedAt?.ToLocalTime().ToString("g")</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(item.ReturnReceiptPath))
                    {
                        <span class="text-success fw-semibold">Uploaded</span>
                    }
                    else
                    {
                        <span class="text-warning fw-semibold">Missing</span>
                    }
                </td>

                <td>
                    <a asp-controller="Items" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                        Edit
                    </a>
                    <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                        Details
                    </a>
                    <a asp-controller="Items" asp-action="ReturnInfo" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                        Return Info
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No returned items yet.</p>
}

