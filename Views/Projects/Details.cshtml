@model Art_BaBomb.Web.Models.Project
@using Microsoft.AspNetCore.Mvc.ViewFeatures

@{
    ViewData["Title"] = "Project Details";

    var neededItems = Model.Items
        .Where(i => i.IsNeeded)
        .OrderBy(i => i.Name)
        .ToList();

    var acquiredItems = Model.Items
        .Where(i => i.IsAcquired && !i.IsReturnRequired && !i.IsReturned)
        .OrderBy(i => i.Name)
        .ToList();

    var returnItems = Model.Items
        .Where(i => i.IsInReturnQueue)
        .OrderBy(i => i.ReturnByDate)
        .ThenBy(i => i.Name)
        .ToList();

    var returnedItems = Model.Items
        .Where(i => i.IsReturned)
        .OrderByDescending(i => i.ReturnedAt)
        .ThenBy(i => i.Name)
        .ToList();

    var neededGroups = neededItems
        .GroupBy(i => string.IsNullOrWhiteSpace(i.Category) ? "Uncategorized" : i.Category.Trim())
        .OrderBy(g => g.Key)
        .ToList();

    var acquiredGroups = acquiredItems
        .GroupBy(i => string.IsNullOrWhiteSpace(i.Category) ? "Uncategorized" : i.Category.Trim())
        .OrderBy(g => g.Key)
        .ToList();

    var returnGroups = returnItems
        .GroupBy(i => string.IsNullOrWhiteSpace(i.Category) ? "Uncategorized" : i.Category.Trim())
        .OrderBy(g => g.Key)
        .ToList();

    var returnedGroups = returnedItems
        .GroupBy(i => string.IsNullOrWhiteSpace(i.Category) ? "Uncategorized" : i.Category.Trim())
        .OrderBy(g => g.Key)
        .ToList();

    var totalEstimated = Model.Items.Sum(i => i.EstimatedCost ?? 0);
    var totalActual = Model.Items.Sum(i => i.ActualCost ?? 0);
    var remainingBudget = Model.Budget - totalActual;

    bool IsImageReceipt(string? path) =>
        !string.IsNullOrWhiteSpace(path) &&
        (path.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));

    // ✅ NEW: Use model logic instead of local helper functions
    var neededAttentionCount = neededItems.Count(i => i.NeedsAttention);
    var acquiredAttentionCount = acquiredItems.Count(i => i.NeedsAttention);
    var returnAttentionCount = returnItems.Count(i => i.NeedsAttention);
    var returnedAttentionCount = returnedItems.Count(i => i.NeedsAttention);
}

<h1>@Model.Name</h1>

<div class="mb-4">
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("g")</p>
</div>

@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["WarningMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- 🔷 Budget Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Budget</h6>
                <div class="fw-bold text-end">
                    @Model.Budget.ToString("C")
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Estimated</h6>
                <div class="fw-bold text-end">
                    @totalEstimated.ToString("C")
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Actual</h6>
                <div class="fw-bold text-end">
                    @totalActual.ToString("C")
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm @(remainingBudget < 0 ? "border-danger" : "")">
            <div class="card-body">
                <h6 class="text-muted">Remaining</h6>
                <div class="fw-bold text-end @(remainingBudget < 0 ? "text-danger" : "")">
                    @remainingBudget.ToString("C")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    @if (User.IsInRole("Admin") || User.IsInRole("Shopper"))
    {
        <a asp-controller="Items"
           asp-action="Create"
           asp-route-projectId="@Model.Id"
           class="btn btn-primary">
            + Add Item
        </a>
    }

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            Edit Project
        </a>
    }

    <a asp-action="Index" class="btn btn-outline-dark">
        Back to Projects
    </a>
</div>

<hr />

<form id="antiForgeryForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<!-- ===================== NEEDED ===================== -->
<h2>
    Needed Items (@neededItems.Count)
    @if (neededAttentionCount > 0)
    {
        <span class="badge bg-warning text-dark ms-2">@neededAttentionCount attention</span>
    }
</h2>
@if (neededGroups.Any())
{
    @foreach (var group in neededGroups)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@group.Key</h5>
                <span class="badge bg-secondary">@group.Count()</span>
            </div>

            <div class="card-body p-0">
                <table class="table table-striped table-hover align-middle mb-0 table-sm">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Notes</th>
                            <th class="text-center">Qty</th>
                            <th>Category</th>
                            <th class="text-end">Est.</th>
                            <th class="text-end">Actual</th>
                            <th class="text-nowrap">Receipt</th>
                            <th class="text-nowrap"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in group)
                    {
                        @await Html.PartialAsync("_ProjectItemRow", item, new ViewDataDictionary(ViewData)
                        {
                            ["Section"] = "Needed",
                            ["CanEdit"] = User.IsInRole("Admin") || User.IsInRole("Shopper"),
                            ["ShowPurchaseFinancials"] = true,
                            ["ShowReturnColumns"] = false,
                            ["ShowReturnedColumns"] = false
                        })
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    <p>No needed items yet.</p>
}

