@model Art_BaBomb.Web.Models.Item

@{
    var section = ViewData["Section"] as string ?? "";
    var canEdit = (bool?)ViewData["CanEdit"] ?? false;
    var showReturnColumns = (bool?)ViewData["ShowReturnColumns"] ?? false;
    var showReturnedColumns = (bool?)ViewData["ShowReturnedColumns"] ?? false;
    var showPurchaseFinancials = (bool?)ViewData["ShowPurchaseFinancials"] ?? false;

    var actionCellClass = section == "ReturnQueue" ? "actions-col-cell actions-col-cell-wide" : "actions-col-cell";

    var useStackedActions = section == "ReturnQueue" || section == "Returned";

    bool IsImageReceipt(string? path) =>
        !string.IsNullOrWhiteSpace(path) &&
        (path.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<tr tabindex="0"
    class="item-row @(Model.NeedsAttention ? "needs-attention" : "") @(Model.HasPastReturnByDate ? "overdue" : "")"
    data-item-id="@Model.Id">

    <td>
        <div class="item-name-cell-content">
            <div class="item-thumb-slot">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <a href="#"
                       data-bs-toggle="modal"
                       data-bs-target="#itemPreviewModal"
                       data-item-src="@Model.ImageUrl"
                       data-item-title="@Model.Name"
                       class="item-preview-trigger">
                        <img src="@Model.ImageUrl"
                             alt="@Model.Name"
                             class="item-thumb rounded border bg-light" />
                    </a>
                }
                else
                {
                    <div class="item-thumb item-thumb-placeholder rounded border bg-light"></div>
                }
            </div>

            <div class="item-name-text">
                <div>@Model.Name</div>

                <div class="mt-1">
                    @if (Model.IsInReturnQueue)
                    {
                        <span class="badge bg-warning text-dark me-1">
                            @(showReturnColumns ? "Return Pending" : "Return")
                        </span>
                    }

                    @if (Model.IsReturned)
                    {
                        <span class="badge bg-secondary me-1">Returned</span>
                    }

                    @if (Model.NeedsPurchaseReceipt)
                    {
                        <span class="badge bg-danger me-1">Needs Receipt</span>
                    }
                </div>
            </div>
        </div>
    </td>

    <td class="notes-col">
        <div class="small text-muted" id="description-display-@Model.Id">
            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <span class="fst-italic">No notes</span>
            }
            else
            {
                @Model.Description
            }
        </div>

        <div class="mt-1 d-none" id="description-editor-@Model.Id">
            <textarea class="form-control form-control-sm mb-2 inline-description-input"
                      id="description-input-@Model.Id"
                      rows="2">@(Model.Description ?? "")</textarea>

            <div class="d-flex gap-1 flex-wrap">
                <button type="button"
                        class="btn btn-sm btn-primary save-description-btn"
                        data-id="@Model.Id">
                    Save
                </button>

                <button type="button"
                        class="btn btn-sm btn-outline-secondary cancel-description-btn"
                        data-id="@Model.Id">
                    Cancel
                </button>
            </div>

            <div class="form-text">Enter to save, Shift+Enter for new line.</div>
        </div>

        <div class="mt-1">
            @if (canEdit)
            {
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <button type="button"
                            class="btn btn-sm btn-link p-0 edit-description-btn"
                            data-id="@Model.Id">
                        ✏️ Edit
                    </button>
                }
                else
                {
                    <button type="button"
                            class="btn btn-sm btn-link p-0 edit-description-btn text-muted"
                            data-id="@Model.Id">
                        + Notes
                    </button>
                }
            }
        </div>
    </td>

    @if (!showReturnedColumns)
    {
        <td class="text-center">
            @if (canEdit)
            {
                <div class="qty-stepper" data-item-id="@Model.Id">
                    <button type="button"
                            class="qty-btn qty-adjust-btn"
                            data-id="@Model.Id"
                            data-delta="-1"
                            @(Model.Quantity <= 1 ? "disabled=\"disabled\"" : "")>
                        −
                    </button>

                    <span class="qty-value" id="qty-value-@Model.Id">@Model.Quantity</span>

                    <button type="button"
                            class="qty-btn qty-adjust-btn"
                            data-id="@Model.Id"
                            data-delta="1">
                        +
                    </button>
                </div>
            }
            else
            {
                <span class="qty-value">@Model.Quantity</span>
            }
        </td>
    }
    else
    {
        <td class="text-center text-nowrap">@Model.Quantity</td>
    }

    <td>@Model.Category</td>

    @if (showPurchaseFinancials)
    {
        <td class="text-end text-nowrap">@Model.EstimatedCost?.ToString("C")</td>
        <td class="text-end text-nowrap">@Model.ActualCost?.ToString("C")</td>

        <td class="text-nowrap receipt-cell">
            @if (IsImageReceipt(Model.PurchaseReceiptPath))
            {
                <a href="#"
                   data-bs-toggle="modal"
                   data-bs-target="#receiptPreviewModal"
                   data-receipt-src="@Model.PurchaseReceiptPath"
                   data-receipt-title="@Model.Name - Receipt"
                   class="receipt-preview-trigger">
                    <img src="@Model.PurchaseReceiptPath"
                         alt="Receipt"
                         class="receipt-thumb rounded border bg-light" />
                </a>
            }
            else if (!string.IsNullOrWhiteSpace(Model.PurchaseReceiptPath))
            {
                <a href="@Model.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary">
                    Receipt
                </a>
            }
            else
            {
                <span class="text-muted">—</span>
            }
        </td>
    }

    @if (showReturnColumns)
    {
        <td>@Model.ReturnLocation</td>
        <td class="text-nowrap">@Model.ReturnByDate?.ToString("d")</td>

        <td class="text-nowrap receipt-cell">
            @if (IsImageReceipt(Model.ReturnReceiptPath))
            {
                <a href="#"
                   data-bs-toggle="modal"
                   data-bs-target="#receiptPreviewModal"
                   data-receipt-src="@Model.ReturnReceiptPath"
                   data-receipt-title="@Model.Name - Return Receipt"
                   class="receipt-preview-trigger">
                    <img src="@Model.ReturnReceiptPath"
                         alt="Return Receipt"
                         class="receipt-thumb rounded border bg-light" />
                </a>
            }
            else if (!string.IsNullOrWhiteSpace(Model.ReturnReceiptPath))
            {
                <a href="@Model.ReturnReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary">
                    Receipt
                </a>
            }
            else
            {
                <span class="text-muted">—</span>
            }
        </td>
    }

    @if (showReturnedColumns)
    {
        <td class="returned-at-cell">@Model.ReturnedAt?.ToLocalTime().ToString("g")</td>

        <td class="text-nowrap receipt-cell">
            @if (IsImageReceipt(Model.ReturnReceiptPath))
            {
                <a href="#"
                   data-bs-toggle="modal"
                   data-bs-target="#receiptPreviewModal"
                   data-receipt-src="@Model.ReturnReceiptPath"
                   data-receipt-title="@Model.Name - Return Receipt"
                   class="receipt-preview-trigger">
                    <img src="@Model.ReturnReceiptPath"
                         alt="Return Receipt"
                         class="receipt-thumb rounded border bg-light" />
                </a>
            }
            else if (!string.IsNullOrWhiteSpace(Model.ReturnReceiptPath))
            {
                <a href="@Model.ReturnReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary">
                    Receipt
                </a>
            }
            else
            {
                <span class="text-muted">—</span>
            }
        </td>

        <td class="text-nowrap">
            @if (!string.IsNullOrWhiteSpace(Model.ReturnReceiptPath))
            {
                <span class="text-success fw-semibold">Complete</span>
            }
            else
            {
                <span class="text-warning fw-semibold">Missing</span>
            }
        </td>
    }

    <td class="@actionCellClass">
        <div class="@(useStackedActions ? "item-action-group item-action-group-stacked" : "item-action-group")">
            @if (canEdit)
            {
                @if (section == "Needed")
                {
                    <form asp-controller="Items" asp-action="MarkAcquired" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-success btn-icon">+</button>
                    </form>

                    <a asp-controller="Items" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        Edit
                    </a>
                }
                else if (section == "Acquired")
                {
                    <form asp-controller="Items" asp-action="MarkNeeded" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-warning btn-icon">-</button>
                    </form>

                    <a asp-controller="Items" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        Edit
                    </a>
                }
                else if (section == "ReturnQueue")
                {
                    <a asp-controller="Items" asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        Return Info
                    </a>

                    <form asp-controller="Items" asp-action="MarkReturned" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Mark Returned</button>
                    </form>
                }
                else if (section == "Returned")
                {
                    <a asp-controller="Items" asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        Return Info
                    </a>
                }
            }

            <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">
                Details
            </a>
        </div>
    </td>
</tr>