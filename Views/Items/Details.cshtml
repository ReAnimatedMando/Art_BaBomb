@model Art_BaBomb.Web.Models.Item
@using Art_BaBomb.Web.Helpers

@{
    ViewData["Title"] = "Item Details";

    bool hasPurchaseReceipt = !string.IsNullOrWhiteSpace(Model.PurchaseReceiptPath);
    bool purchaseReceiptIsImage =
        hasPurchaseReceipt &&
        (Model.PurchaseReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));

    bool hasReturnReceipt = !string.IsNullOrWhiteSpace(Model.ReturnReceiptPath);
    bool returnReceiptIsImage =
        hasReturnReceipt &&
        (Model.ReturnReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@Model.Name</h1>
        <div class="text-muted">
            Project: <strong>@Model.Project?.Name</strong>
        </div>
    </div>

    <div class="text-end">
        @if (string.IsNullOrWhiteSpace(Model.Status) || Model.Status.Trim().Equals("Needed", StringComparison.OrdinalIgnoreCase))
        {
            <span class="badge bg-secondary fs-6">Needed</span>
        }
        else if ((Model.Status ?? "").Trim().Equals("Acquired", StringComparison.OrdinalIgnoreCase))
        {
            <span class="badge bg-success fs-6">Acquired</span>
        }

        @if (Model.IsReturnRequired && !Model.IsReturned)
        {
            <span class="badge bg-warning text-dark fs-6 ms-1">In Return Queue</span>
        }

        @if (Model.IsReturned)
        {
            <span class="badge bg-danger fs-6 ms-1">Returned</span>
        }
    </div>
</div>

@if (Model.IsReturned)
{
    <div class="alert alert-danger text-center fw-bold fs-4 mb-4 shadow-sm">
        RETURNED
        @if (Model.ReturnedAt.HasValue)
        {
            <div class="fs-6 fw-normal mt-2">
                Returned on @Model.ReturnedAt.Value.ToLocalTime().ToString("g")
            </div>
        }
    </div>

    @if (string.IsNullOrWhiteSpace(Model.ReturnReceiptPath))
    {
        <div class="alert alert-warning text-center fw-bold mb-4 shadow-sm">
            Returned item is missing a return receipt.
        </div>
    }
}
else if (Model.IsReturnRequired)
{
    <div class="alert alert-warning text-center fw-bold fs-5 mb-4 shadow-sm">
        IN RETURN QUEUE
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Item Information</h5>

                <dl class="row mb-0">

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4">Estimated Cost</dt>
                    <dd class="col-sm-8 text-end">@Model.EstimatedCost?.ToString("C")</dd>

                    <dt class="col-sm-4">Actual Cost</dt>
                    <dd class="col-sm-8 text-end">@Model.ActualCost?.ToString("C")</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <dt class="col-sm-4">Image URL</dt>
                        <dd class="col-sm-8">
                            <a href="@Model.ImageUrl" target="_blank">@Model.ImageUrl</a>
                        </dd>
                    }
                </dl>
            </div>
        </div>

        @if (Model.IsReturnRequired || Model.IsReturned)
        {
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Return Information</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Return Location</dt>
                        <dd class="col-sm-8">
                            @(string.IsNullOrWhiteSpace(Model.ReturnLocation) ? "—" : Model.ReturnLocation)
                        </dd>

                        <dt class="col-sm-4">Return By Date</dt>
                        <dd class="col-sm-8">
                            @(Model.ReturnByDate?.ToString("d") ?? "—")
                        </dd>

                        <dt class="col-sm-4">Return Notes</dt>
                        <dd class="col-sm-8">
                            @(string.IsNullOrWhiteSpace(Model.ReturnNotes) ? "—" : Model.ReturnNotes)
                        </dd>

                        @if (Model.IsReturned)
                        {
                            <dt class="col-sm-4">Returned At</dt>
                            <dd class="col-sm-8">@Model.ReturnedAt?.ToLocalTime().ToString("g")</dd>
                        }
                    </dl>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Purchase Receipt</h5>

                @if (hasPurchaseReceipt)
                {
                    @if (purchaseReceiptIsImage)
                    {
                        <a href="@Model.PurchaseReceiptPath" target="_blank">
                            <img src="@Model.PurchaseReceiptPath"
                                 alt="Purchase Receipt"
                                 class="img-fluid rounded border mb-3" />
                        </a>
                    }

                    <a href="@Model.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary">
                        View Purchase Receipt
                    </a>

                    <div class="small text-muted mt-2">
                        @Model.PurchaseReceiptFileName
                        @if (Model.PurchaseReceiptSizeBytes.HasValue)
                        {
                            <span>• @FileSizeHelper.FormatFileSize(Model.PurchaseReceiptSizeBytes)</span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No purchase receipt uploaded.</p>
                }
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="PurchaseReceipt" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                Manage Purchase Receipt
            </a>
        </div>

        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Return Receipt</h5>

                @if (hasReturnReceipt)
                {
                    @if (returnReceiptIsImage)
                    {
                        <a href="@Model.ReturnReceiptPath" target="_blank">
                            <img src="@Model.ReturnReceiptPath"
                                 alt="Return Receipt"
                                 class="img-fluid rounded border mb-3" />
                        </a>
                    }

                    <a href="@Model.ReturnReceiptPath" target="_blank" class="btn btn-sm btn-outline-danger">
                        View Return Receipt
                    </a>

                    <div class="small text-muted mt-2">
                        @Model.ReturnReceiptFileName
                        @if (Model.ReturnReceiptSizeBytes.HasValue)
                        {
                            <span>• @FileSizeHelper.FormatFileSize(Model.ReturnReceiptSizeBytes)</span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No return receipt uploaded.</p>
                }
            </div>
            
        </div>

        @if (Model.IsReturnRequired || Model.IsReturned)
        {
            <div class="mt-3">
                <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">
                    Manage Return Receipt
                </a>
            </div>
        }

        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Actions</h5>

                <div class="d-grid gap-2">
                    @if (!Model.IsReturnRequired && !Model.IsReturned)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            Edit Item
                        </a>

                        <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-warning">
                            Start Return Workflow
                        </a>
                    }
                    else if (Model.IsReturnRequired && !Model.IsReturned)
                    {
                        <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                            Edit Return Info
                        </a>

                        <form asp-action="MarkReturned" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger w-100">
                                Mark Returned
                            </button>
                        </form>
                    }
                    else if (Model.IsReturned)
                    {
                        <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                            View / Update Return Info
                        </a>
                    }

                    <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-outline-dark">
                        Back to Project
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>