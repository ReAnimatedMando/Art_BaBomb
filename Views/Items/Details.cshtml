@model Art_BaBomb.Web.Models.Item
@using Art_BaBomb.Web.Helpers

@{
    ViewData["Title"] = "Item Details";

    bool hasPurchaseReceipt = !string.IsNullOrWhiteSpace(Model.PurchaseReceiptPath);
    bool purchaseReceiptIsImage =
        hasPurchaseReceipt &&
        (Model.PurchaseReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));

    bool hasReturnReceipt = !string.IsNullOrWhiteSpace(Model.ReturnReceiptPath);
    bool returnReceiptIsImage =
        hasReturnReceipt &&
        (Model.ReturnReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3 item-details-header">
    <div>
        <h1 class="page-title mb-1">@Model.Name</h1>
        <div class="text-muted">
            Project: <strong>@Model.Project?.Name</strong>
        </div>
    </div>

    <div class="text-end item-details-status-badges">
        @if (string.IsNullOrWhiteSpace(Model.Status) || Model.Status.Trim().Equals("Needed", StringComparison.OrdinalIgnoreCase))
        {
            <span class="badge bg-secondary fs-6">Needed</span>
        }
        else if ((Model.Status ?? "").Trim().Equals("Acquired", StringComparison.OrdinalIgnoreCase))
        {
            <span class="badge bg-success fs-6">Acquired</span>
        }

        @if (Model.IsReturnRequired && !Model.IsReturned)
        {
            <span class="badge bg-warning text-dark fs-6 ms-1">In Return Queue</span>
        }

        @if (Model.IsReturned)
        {
            <span class="badge bg-danger fs-6 ms-1">Returned</span>
        }
    </div>
</div>

@{
    string? statusPanelClass = null;
    string? statusPanelTitle = null;
    string? statusPanelMessage = null;

    if (Model.IsReturned)
    {
        statusPanelClass = "item-status-panel item-status-panel-danger";
        statusPanelTitle = "Returned";
        statusPanelMessage = Model.ReturnedAt.HasValue
            ? $"Returned on {Model.ReturnedAt.Value.ToLocalTime():g}"
            : "This item has been marked as returned.";
    }
    else if (Model.IsReturnRequired)
    {
        statusPanelClass = "item-status-panel item-status-panel-warning";
        statusPanelTitle = "In Return Queue";

        if (!Model.ReturnByDate.HasValue)
        {
            statusPanelMessage = "This item is in the return workflow but has no return-by date.";
        }
        else if (Model.ReturnByDate.Value.Date < DateTime.Today)
        {
            statusPanelMessage = "This item has a return-by date in the past.";
        }
        else
        {
            statusPanelMessage = $"Return by {Model.ReturnByDate.Value:d}.";
        }
    }
    else if (Model.ActualCost.HasValue && string.IsNullOrWhiteSpace(Model.PurchaseReceiptPath))
    {
        statusPanelClass = "item-status-panel item-status-panel-warning";
        statusPanelTitle = "Purchase Receipt Needed";
        statusPanelMessage = "This item has an actual cost but is missing a purchase receipt.";
    }

    if (Model.IsReturned && string.IsNullOrWhiteSpace(Model.ReturnReceiptPath))
    {
        statusPanelClass = "item-status-panel item-status-panel-warning";
        statusPanelTitle = "Return Receipt Needed";
        statusPanelMessage = "This item is missing a return receipt.";
    }
}

@if (!string.IsNullOrWhiteSpace(statusPanelTitle))
{
    <div class="@statusPanelClass mb-4">
        <div class="item-status-panel-title">@statusPanelTitle</div>
        @if (!string.IsNullOrWhiteSpace(statusPanelMessage))
        {
            <div class="item-status-panel-message">@statusPanelMessage</div>
        }
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Item Information</h5>

                <dl class="row mb-0 item-detail-list">

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4">Estimated Cost</dt>
                    <dd class="col-sm-8">@Model.EstimatedCost?.ToString("C")</dd>

                    <dt class="col-sm-4">Actual Cost</dt>
                    <dd class="col-sm-8">@Model.ActualCost?.ToString("C")</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <dt class="col-sm-4">Image URL</dt>
                        <dd class="col-sm-8">
                            <a href="@Model.ImageUrl" target="_blank">@Model.ImageUrl</a>
                        </dd>
                    }
                </dl>
            </div>
        </div>

        @if (Model.IsReturnRequired || Model.IsReturned)
        {
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Return Information</h5>

                    <dl class="row mb-0 item-detail-list">
                        <dt class="col-sm-4">Return Location</dt>
                        <dd class="col-sm-8">
                            @(string.IsNullOrWhiteSpace(Model.ReturnLocation) ? "—" : Model.ReturnLocation)
                        </dd>

                        <dt class="col-sm-4">Return By Date</dt>
                        <dd class="col-sm-8">
                            @(Model.ReturnByDate?.ToString("d") ?? "—")
                        </dd>

                        <dt class="col-sm-4">Return Notes</dt>
                        <dd class="col-sm-8">
                            @(string.IsNullOrWhiteSpace(Model.ReturnNotes) ? "—" : Model.ReturnNotes)
                        </dd>

                        @if (Model.IsReturned)
                        {
                            <dt class="col-sm-4">Returned At</dt>
                            <dd class="col-sm-8">@Model.ReturnedAt?.ToLocalTime().ToString("g")</dd>
                        }
                    </dl>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Purchase Receipt</h5>

                @if (hasPurchaseReceipt)
                {
                    @if (purchaseReceiptIsImage)
                    {
                        <a href="#" data-bs-toggle="modal" data-bs-target="#receiptPreviewModal" data-receipt-src="@Model.PurchaseReceiptPath" data-receipt-title="@Model.Name - Purchase Receipt" class="receipt-preview-trigger receipt-preview-large">
                            <span class="receipt-preview-surface">
                                <img src="@Model.PurchaseReceiptPath" alt="Purchase Receipt" class="receipt-preview-image" />
                            </span>
                        </a>

                        <div class="small text-muted mt-2">
                            Click the receipt preview to enlarge it.
                        </div>
                    }
                    else
                    {
                        <div class="receipt-preview-surface receipt-preview-large d-flex align-items-center justify-content-center text-muted small">
                            Receipt uploaded
                        </div>
                    }

                    <div class="small text-muted mt-2">
                        @Model.PurchaseReceiptFileName
                        @if (Model.PurchaseReceiptSizeBytes.HasValue)
                        {
                            <span>• @FileSizeHelper.FormatFileSize(Model.PurchaseReceiptSizeBytes)</span>
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state-text">No purchase receipt uploaded.</p>
                }
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="PurchaseReceipt" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                Update Purchase Receipt
            </a>
        </div>

        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Return Receipt</h5>

                @if (hasReturnReceipt)
                {
                    @if (returnReceiptIsImage)
                    {
                        <a href="#" data-bs-toggle="modal" data-bs-target="#receiptPreviewModal" data-receipt-src="@Model.ReturnReceiptPath" data-receipt-title="@Model.Name - Return Receipt" class="receipt-preview-trigger receipt-preview-large">
                            <span class="receipt-preview-surface">
                                <img src="@Model.ReturnReceiptPath" alt="Return Receipt" class="receipt-preview-image" />
                            </span>
                        </a>

                        <div class="small text-muted mt-2">
                            Click the receipt preview to enlarge it.
                        </div>
                    }
                    else
                    {
                        <div class="receipt-preview-surface receipt-preview-large d-flex align-items-center justify-content-center text-muted small">
                            Receipt uploaded
                        </div>
                    }

                    <div class="small text-muted mt-2">
                        @Model.ReturnReceiptFileName
                        @if (Model.ReturnReceiptSizeBytes.HasValue)
                        {
                            <span>• @FileSizeHelper.FormatFileSize(Model.ReturnReceiptSizeBytes)</span>
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state-text">No return receipt uploaded.</p>
                }
            </div>
        </div>

        @if (Model.IsReturnRequired || Model.IsReturned)
        {
            <div class="mt-3">
                <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">
                    Update Return Receipt
                </a>
            </div>
        }
    </div>

        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Actions</h5>

                <div class="item-actions-panel">
                    @if (!Model.IsReturnRequired && !Model.IsReturned)
                    {
                        <div class="item-actions-group">
                            <div class="item-actions-group-label">Item</div>

                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                                Edit Item
                            </a>
                        </div>

                        <div class="item-actions-group">
                            <div class="item-actions-group-label">Return Workflow</div>

                            <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-warning">
                                Start Return
                            </a>
                        </div>
                    }
                    else if (Model.IsReturnRequired && !Model.IsReturned)
                    {
                        <div class="item-actions-group">
                            <div class="item-actions-group-label">Return Workflow</div>

                            <form asp-action="MarkReturned" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger w-100">
                                    Mark Returned
                                </button>
                            </form>

                            <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                                Edit Return Info
                            </a>
                        </div>
                    }
                    else if (Model.IsReturned)
                    {
                        <div class="item-actions-group">
                            <div class="item-actions-group-label">Return Workflow</div>

                            <a asp-action="ReturnInfo" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                                View / Update Return Info
                            </a>
                        </div>
                    }

                    <div class="item-actions-group item-actions-group-secondary">
                        <div class="item-actions-group-label">Navigation</div>

                        <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-outline-dark">
                            Back to Project
                        </a>
                    </div>
                </div>
            </div>
        </div>
</div>

