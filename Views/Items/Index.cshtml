@model IEnumerable<Art_BaBomb.Web.Models.Item>

@{
    ViewData["Title"] = "Index";
}

@{
    var projectName = ViewBag.ProjectName as string;
    var projectId = ViewBag.ProjectId as int?;

    bool IsImageReceipt(string? path) =>
        !string.IsNullOrWhiteSpace(path) &&
        (path.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || path.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<h1>
    @if (!string.IsNullOrEmpty(projectName))
    {
        @:Items for @projectName
    }
    else
    {
        @:All Items
    }
</h1>

<p>
    <a asp-action="Create" asp-route-projectId="@projectId" class="btn btn-primary">Create New Item</a>
</p>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Project)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ItemNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstimatedCost)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ActualCost)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImageUrl)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Project.Name)
            </td>
            <td>
                <div class="d-flex align-items-start gap-2">
                    @{
                        var previewPath = !string.IsNullOrWhiteSpace(item.PurchaseReceiptPath)
                            ? item.PurchaseReceiptPath
                            : item.ReturnReceiptPath;
                    }

                    @if (IsImageReceipt(previewPath))
                    {
                        <a href="@previewPath" target="_blank">
                            <img src="@previewPath"
                                alt="Receipt"
                                style="width: 42px; height: 42px; object-fit: cover;"
                                class="rounded border" />
                        </a>
                    }

                    <div>
                        <div>@item.Name</div>

                        <div class="mt-1">
                            @if (!string.IsNullOrWhiteSpace(item.PurchaseReceiptPath) && !IsImageReceipt(item.PurchaseReceiptPath))
                            {
                                <a href="@item.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary me-1">
                                    Purchase Receipt
                                </a>
                            }

                            @if (!string.IsNullOrWhiteSpace(item.ReturnReceiptPath) && !IsImageReceipt(item.ReturnReceiptPath))
                            {
                                <a href="@item.ReturnReceiptPath" target="_blank" class="btn btn-sm btn-outline-danger me-1">
                                    Return Receipt
                                </a>
                            }

                            @if (!string.IsNullOrWhiteSpace(item.PurchaseReceiptPath))
                            {
                                <span class="badge bg-info text-dark me-1">Purchase Receipt</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(item.ReturnReceiptPath))
                            {
                                <span class="badge bg-danger me-1">Return Receipt</span>
                            }

                            @if (item.IsReturnRequired && !item.IsReturned)
                            {
                                <span class="badge bg-warning text-dark me-1">Return Queue</span>
                            }

                            @if (item.IsReturned)
                            {
                                <span class="badge bg-danger me-1">Returned</span>
                            }
                        </div>
                    </div>
                </div>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ItemNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EstimatedCost)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ActualCost)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ImageUrl)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
