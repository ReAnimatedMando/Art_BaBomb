@model Art_BaBomb.Web.Models.Item

@{
    ViewData["Title"] = "Delete Item";
}

<section class="form-hero mb-4">
    <div>
        <div class="eyebrow text-danger">Danger Zone</div>
        <h1 class="form-hero-title">Delete Item</h1>

        <p class="form-hero-subtitle">
            You are about to permanently delete <strong>@Model.Name</strong>.
        </p>
    </div>
</section>

<div class="form-shell">

    <section class="form-section-card border-danger-subtle">
        <h2 class="text-danger">Confirm Deletion</h2>

        <div class="alert alert-danger">
            ⚠ This action cannot be undone.
        </div>

        <dl class="row mb-4 item-detail-list">

            <dt class="col-sm-3">Project</dt>
            <dd class="col-sm-9">@Model.Project?.Name</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Scene</dt>
            <dd class="col-sm-9">@Model.Scene</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)
            </dd>

            <dt class="col-sm-3">Estimated Cost</dt>
            <dd class="col-sm-9">@Model.EstimatedCost?.ToString("C")</dd>

            <dt class="col-sm-3">Actual Cost</dt>
            <dd class="col-sm-9">@Model.ActualCost?.ToString("C")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="form-actions">
                <button type="submit" class="btn btn-danger">
                    Delete Item
                </button>

                <a asp-controller="Projects"
                   asp-action="Details"
                   asp-route-id="@Model.ProjectId"
                   class="btn btn-art-outline">
                    Cancel
                </a>
            </div>
        </form>

    </section>

</div>
