@model Art_BaBomb.Web.Models.Item
@using Art_BaBomb.Web.Helpers

@{
    ViewData["Title"] = "Manage Purchase Receipt";

    bool hasPurchaseReceipt = !string.IsNullOrWhiteSpace(Model.PurchaseReceiptPath);
    bool purchaseReceiptIsImage =
        hasPurchaseReceipt &&
        (Model.PurchaseReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<h1>Manage Purchase Receipt</h1>
<h4 class="text-muted">@Model.Name</h4>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="PurchaseReceipt" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Upload Purchase Receipt</label>

                <div id="purchaseReceiptDropZone" class="receipt-drop-zone" role="button" tabindex="0">
                    <div class="fw-semibold">Drag & drop receipt here</div>
                    <div class="text-muted small">or click to choose a file</div>

                    <input type="file"
                        id="purchaseReceiptFile"
                        name="purchaseReceiptFile"
                        class="d-none"
                        accept=".jpg,.jpeg,.png,.webp,.pdf" />
                </div>

                @Html.ValidationMessage("purchaseReceiptFile", new { @class = "text-danger d-block mt-1" })
                <div id="purchaseReceiptSelectedFile" class="form-text">Upload purchase receipt image or PDF.</div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Save Purchase Receipt</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back to Item</a>
            </div>
        </form>

        @if (hasPurchaseReceipt)
        {
            <hr />

            @if (purchaseReceiptIsImage)
            {
                <a href="#"
                data-bs-toggle="modal"
                data-bs-target="#receiptPreviewModal"
                data-receipt-src="@Model.PurchaseReceiptPath"
                data-receipt-title="@Model.Name - Purchase Receipt"
                class="receipt-preview-trigger">
                    <img src="@Model.PurchaseReceiptPath"
                        alt="Purchase Receipt"
                        class="img-fluid rounded border mb-3" />
                </a>
            }

            <a href="@Model.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary">
                View Current Receipt
            </a>

            <form asp-action="DeletePurchaseReceipt" asp-route-id="@Model.Id" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this purchase receipt?');">
                    Delete Receipt
                </button>
            </form>

            <div class="small text-muted mt-2">
                @Model.PurchaseReceiptFileName
                @if (Model.PurchaseReceiptSizeBytes.HasValue)
                {
                    <span>• @FileSizeHelper.FormatFileSize(Model.PurchaseReceiptSizeBytes)</span>
                }
            </div>
        }
        else
        {
            <hr />
            <p class="text-muted mb-0">No purchase receipt uploaded.</p>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const fileInput = document.getElementById("purchaseReceiptFile");
            const dropZone = document.getElementById("purchaseReceiptDropZone");
            const selectedFile = document.getElementById("purchaseReceiptSelectedFile");

            if (!fileInput || !dropZone || !selectedFile) return;

            dropZone.addEventListener("click", function () {
                fileInput.click();
            });

            fileInput.addEventListener("change", function () {
                selectedFile.textContent = this.files.length > 0
                    ? `Selected: ${this.files[0].name}`
                    : "Upload purchase receipt image or PDF.";
            });

            ["dragenter", "dragover"].forEach(eventName => {
                dropZone.addEventListener(eventName, function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    dropZone.classList.add("dragover");
                });
            });

            ["dragleave", "drop"].forEach(eventName => {
                dropZone.addEventListener(eventName, function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    dropZone.classList.remove("dragover");
                });
            });

            dropZone.addEventListener("drop", function (e) {
                const files = e.dataTransfer.files;
                if (files && files.length > 0) {
                    fileInput.files = files;
                    selectedFile.textContent = `Selected: ${files[0].name}`;
                }
            });
        });

    </script>
}