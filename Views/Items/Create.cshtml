@model Art_BaBomb.Web.Models.Item

@{
    ViewData["Title"] = "Create Item";
}

<section class="form-hero mb-4">
    <div>
        <div class="eyebrow">New Item</div>
        <h1 class="form-hero-title">Create Item</h1>
        <p class="form-hero-subtitle">
            Add a needed or acquired item to <strong>@ViewBag.ProjectName</strong>.
        </p>
    </div>
</section>

<div class="form-shell">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger stack-md"></div>

        <input type="hidden" asp-for="ProjectId" />

        <section class="form-section-card">
            <h2>Item Basics</h2>

            <div class="stack-md">
                <label asp-for="Name" class="form-label">Item Name</label>
                <input asp-for="Name" class="form-control" autofocus />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" type="number" min="1" max="9999" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Scene" class="form-label"></label>
                    <input asp-for="Scene"
                           class="form-control"
                           list="sceneOptions"
                           placeholder="Kitchen, Scene 12, INT. Office..." />
                    <datalist id="sceneOptions">
                        @foreach (var scene in ViewBag.ExistingScenes as List<string> ?? new List<string>())
                        {
                            <option value="@scene"></option>
                        }
                    </datalist>
                    <div class="form-text">Use an existing scene or type a new one.</div>
                    <span asp-validation-for="Scene" class="text-danger"></span>
                </div>
            </div>

            <div class="stack-md">
                <label asp-for="Description" class="form-label">Notes / Description</label>
                <textarea asp-for="Description"
                          class="form-control"
                          rows="4"
                          placeholder="Where to source it, notes for shoppers, details, etc."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </section>

        <section class="form-section-card">
            <h2>Cost & Status</h2>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="EstimatedCost" class="form-label">Estimated Cost</label>
                    <input asp-for="EstimatedCost" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="EstimatedCost" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ActualCost" class="form-label">Actual Cost</label>
                    <input asp-for="ActualCost" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="ActualCost" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Needed">Needed</option>
                        <option value="Acquired">Acquired</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="form-section-card">
            <h2>Item Image</h2>

            <div class="stack-md">
                <label asp-for="ImageUrl" class="form-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div>
                <label class="form-label">Or Upload Image</label>
                <input type="file"
                       name="imageFile"
                       class="form-control"
                       accept=".jpg,.jpeg,.png,.webp" />
                <div class="form-text">JPEG, PNG, or WEBP files are supported.</div>
                <span class="text-danger">@Html.ValidationMessage("imageFile")</span>
            </div>
        </section>

        <div class="form-actions">
            <button type="submit" class="btn btn-art-primary">
                Create Item
            </button>

            <a asp-controller="Projects"
               asp-action="Details"
               asp-route-id="@Model.ProjectId"
               class="btn btn-art-outline">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}