@model Art_BaBomb.Web.Models.Item

@{
    ViewData["Title"] = "Edit Item";

    bool hasPurchaseReceipt = !string.IsNullOrWhiteSpace(Model.PurchaseReceiptPath);
    bool purchaseIsImage =
        hasPurchaseReceipt &&
        (Model.PurchaseReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<h1>Edit Item</h1>
<h4 class="text-muted">@Model.Name</h4>
<hr />

@if (Model.IsReturnRequired || Model.IsReturned)
{
    <div class="alert alert-warning">
        This item is in the return workflow. Use the Return Info page to manage return details.
    </div>
}

<form asp-action="Edit" enctype="multipart/form-data">

    <div class="row g-4">

        <!-- LEFT SIDE: FORM -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="ProjectId" class="form-label"></label>
                        <select asp-for="ProjectId" class="form-select" asp-items="ViewBag.ProjectId"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>                            <input asp-for="Name" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" max="9999" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label"></label>
                        <input asp-for="Category" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="EstimatedCost" class="form-label"></label>
                            <input asp-for="EstimatedCost" class="form-control" type="number" step="0.01" min="0" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ActualCost" class="form-label"></label>
                            <input asp-for="ActualCost" class="form-control" type="number" step="0.01" min="0" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Needed">Needed</option>
                            <option value="Acquired">Acquired</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label"></label>
                        <input asp-for="ImageUrl" class="form-control" />
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-controller="Projects"
                           asp-action="Details"
                           asp-route-id="@Model.ProjectId"
                           class="btn btn-outline-dark">
                            Back to Project
                        </a>
                    </div>

                </div>
            </div>
        </div>

        <!-- RIGHT SIDE: RECEIPTS -->
        <div class="col-lg-5">

            <!-- PURCHASE RECEIPT -->
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Purchase Receipt</h5>

                    <div class="mb-3">
                        <input type="file" name="purchaseReceiptFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.pdf" />
                        @Html.ValidationMessage("purchaseReceiptFile", new { @class = "text-danger d-block mt-1" })
                        <div class="form-text">Upload purchase receipt (image or PDF)</div>
                    </div>

                    @if (hasPurchaseReceipt)
                    {
                        @if (purchaseIsImage)
                        {
                            <a href="@Model.PurchaseReceiptPath" target="_blank">
                                <img src="@Model.PurchaseReceiptPath"
                                 class="img-fluid rounded border mb-3" />
                            </a>
                        }

                        <a href="@Model.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-primary">
                            View Receipt
                        </a>

                        <div class="small text-muted mt-2">
                            @Model.PurchaseReceiptFileName
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No purchase receipt uploaded.</p>
                    }
                </div>
            </div>

        </div>
    </div>

</form>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}