@using Art_BaBomb.Web.Helpers
@model Art_BaBomb.Web.Models.Item

@{
    ViewData["Title"] = "Edit Item";

    bool hasPurchaseReceipt = !string.IsNullOrWhiteSpace(Model.PurchaseReceiptPath);
    bool purchaseIsImage =
        hasPurchaseReceipt &&
        (Model.PurchaseReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.PurchaseReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<section class="form-hero mb-4">
    <div>
        <div class="eyebrow">Update Item</div>
        <h1 class="form-hero-title">Edit Item</h1>
        <p class="form-hero-subtitle">
            Update item details, cost, image, and purchase receipt for <strong>@Model.Name</strong>.
        </p>
    </div>
</section>

@if (Model.IsReturnRequired || Model.IsReturned)
{
    <div class="alert alert-warning">
        This item is in the return workflow. Use the Return Info page to manage return details.
    </div>
}

<form asp-action="Edit" enctype="multipart/form-data">
    <div class="row g-4">

        <div class="col-lg-7">
            <div class="form-shell">
                <div asp-validation-summary="ModelOnly" class="text-danger stack-md"></div>

                <input type="hidden" asp-for="Id" />

                <section class="form-section-card">
                    <h2>Item Basics</h2>

                    <div class="stack-md">
                        <label asp-for="ProjectId" class="form-label"></label>
                        <select asp-for="ProjectId" class="form-select" asp-items="ViewBag.ProjectId"></select>
                    </div>

                    <div class="stack-md">
                        <label asp-for="Name" class="form-label">Item Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" type="number" min="1" max="9999" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Scene" class="form-label"></label>
                            <input asp-for="Scene"
                                   class="form-control"
                                   list="sceneOptions"
                                   placeholder="Kitchen, Scene 12, INT. Office..." />
                            <datalist id="sceneOptions">
                                @foreach (var scene in ViewBag.ExistingScenes ?? new List<string>())
                                {
                                    <option value="@scene"></option>
                                }
                            </datalist>
                            <div class="form-text">Use an existing scene or type a new one.</div>
                            <span asp-validation-for="Scene" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="stack-md">
                        <label asp-for="Description" class="form-label">Notes / Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </section>

                <section class="form-section-card">
                    <h2>Cost & Status</h2>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="EstimatedCost" class="form-label">Estimated Cost</label>
                            <input asp-for="EstimatedCost" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="EstimatedCost" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ActualCost" class="form-label">Actual Cost</label>
                            <input asp-for="ActualCost" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="ActualCost" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Needed">Needed</option>
                                <option value="Acquired">Acquired</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <section class="form-section-card">
                    <h2>Item Image</h2>

                    <div class="stack-md">
                        <label asp-for="ImageUrl" class="form-label">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                    {
                        <div class="stack-md">
                            <label class="form-label">Current Uploaded Image</label>
                            <div>
                                <img src="@Url.Content(Model.ImagePath)"
                                     alt="@Model.Name"
                                     class="img-fluid rounded shadow-sm"
                                     style="max-height: 220px;" />
                            </div>
                            <div class="small text-muted mt-2">
                                @Model.ImageFileName
                                @if (Model.ImageSizeBytes.HasValue)
                                {
                                    <span>• @FileSizeHelper.FormatFileSize(Model.ImageSizeBytes)</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="stack-md">
                        <label class="form-label">Replace / Upload Image</label>
                        <input type="file"
                               name="imageFile"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.webp" />
                        <div class="form-text">JPEG, PNG, or WEBP files are supported.</div>
                        <span class="text-danger">@Html.ValidationMessage("imageFile")</span>
                    </div>
                </section>

                <div class="form-actions">
                    <button type="submit" class="btn btn-art-primary">
                        Save Changes
                    </button>

                    <a asp-controller="Projects"
                       asp-action="Details"
                       asp-route-id="@Model.ProjectId"
                       class="btn btn-art-outline">
                        Back to Project
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="form-shell">
                <section class="form-section-card">
                    <h2>Purchase Receipt</h2>

                    <div class="stack-md">
                        <label class="form-label">Upload / Replace Receipt</label>
                        <input type="file"
                               name="purchaseReceiptFile"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.webp,.pdf" />
                        @Html.ValidationMessage("purchaseReceiptFile", new { @class = "text-danger d-block mt-1" })
                        <div class="form-text">Upload purchase receipt image or PDF.</div>
                    </div>

                    @if (hasPurchaseReceipt)
                    {
                        @if (purchaseIsImage)
                        {
                            <a href="#"
                               data-bs-toggle="modal"
                               data-bs-target="#receiptPreviewModal"
                               data-receipt-src="@Model.PurchaseReceiptPath"
                               data-receipt-title="@Model.Name - Receipt"
                               class="receipt-preview-trigger">
                                <img src="@Model.PurchaseReceiptPath"
                                     alt="Receipt"
                                     style="width: 44px; height: 44px; object-fit: cover;"
                                     class="rounded border bg-light" />
                            </a>
                        }

                        <div class="small text-muted mt-2">
                            @Model.PurchaseReceiptFileName
                        </div>
                    }
                    else
                    {
                        <p class="empty-state-text">No purchase receipt uploaded.</p>
                    }
                </section>
            </div>
        </div>

    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}