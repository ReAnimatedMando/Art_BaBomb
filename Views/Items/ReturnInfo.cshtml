@model Art_BaBomb.Web.Models.Item
@using Art_BaBomb.Web.Helpers

@{
    ViewData["Title"] = "Return Info";

    bool hasReturnReceipt = !string.IsNullOrWhiteSpace(Model.ReturnReceiptPath);
    bool returnReceiptIsImage =
        hasReturnReceipt &&
        (Model.ReturnReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<section class="form-hero mb-4">
    <div>
        <div class="eyebrow">Return Workflow</div>
        <h1 class="form-hero-title">Return Info</h1>
        <p class="form-hero-subtitle">
            Manage return details for <strong>@Model.Name</strong>
            @if (!string.IsNullOrWhiteSpace(Model.Project?.Name))
            {
                <span> in <strong>@Model.Project.Name</strong></span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Scene))
            {
                <span> — @Model.Scene</span>
            }
        </p>
    </div>
</section>

@if (Model.IsReturned && string.IsNullOrWhiteSpace(Model.ReturnReceiptPath))
{
    <div class="alert alert-warning fw-bold mb-4">
        This item is marked returned, but a return receipt has not been uploaded yet.
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="form-shell">
            <section class="form-section-card">
                <h2>Return Workflow</h2>

                <form asp-action="ReturnInfo" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger stack-md"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProjectId" />
                    <input type="hidden" asp-for="Name" />
                    <input type="hidden" asp-for="Scene" />
                    <input type="hidden" asp-for="Description" />
                    <input type="hidden" asp-for="EstimatedCost" />
                    <input type="hidden" asp-for="ActualCost" />
                    <input type="hidden" asp-for="Status" />
                    <input type="hidden" asp-for="ImageUrl" />
                    <input type="hidden" asp-for="IsReturnRequired" value="true" />

                    <div class="stack-md">
                        <label asp-for="ReturnLocation" class="form-label"></label>
                        <input asp-for="ReturnLocation" class="form-control" autofocus />
                        <span asp-validation-for="ReturnLocation" class="text-danger"></span>
                    </div>

                    <div class="stack-md">
                        <label asp-for="ReturnByDate" class="form-label"></label>
                        <input asp-for="ReturnByDate" class="form-control" type="date" />
                        <span asp-validation-for="ReturnByDate" class="text-danger"></span>
                    </div>

                    <div class="stack-md">
                        <label asp-for="ReturnNotes" class="form-label"></label>
                        <textarea asp-for="ReturnNotes" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="ReturnNotes" class="text-danger"></span>
                    </div>

                    <div class="stack-md">
                        <label class="form-label">Return Receipt</label>

                        <div id="returnReceiptDropZone" class="receipt-drop-zone" role="button" tabindex="0">
                            <div class="fw-semibold">Drag & drop receipt here</div>
                            <div class="text-muted small">or click to choose a file</div>

                            <input type="file"
                                id="returnReceiptFile"
                                name="returnReceiptFile"
                                class="d-none"
                                accept=".jpg,.jpeg,.png,.webp,.pdf" />
                        </div>

                        @Html.ValidationMessage("returnReceiptFile", new { @class = "text-danger d-block mt-1" })
                        <div id="returnReceiptSelectedFile" class="form-text">Upload a return receipt image or PDF. Max file size: 10 MB.</div>
                    </div>

                    @if (hasReturnReceipt)
                    {
                        <div class="form-check stack-md">
                            <input class="form-check-input" type="checkbox" id="removeReturnReceipt" name="removeReturnReceipt" value="true" />
                            <label class="form-check-label" for="removeReturnReceipt">
                                Delete current return receipt
                            </label>
                        </div>
                    }

                    <div class="form-check stack-md">
                        <input class="form-check-input" asp-for="IsReturned" />
                        <label class="form-check-label" asp-for="IsReturned"></label>
                    </div>

                    @if (Model.IsReturned && Model.ReturnedAt.HasValue)
                    {
                        <div class="item-inline-status mb-4">
                            <strong>Returned At:</strong> @Model.ReturnedAt.Value.ToLocalTime().ToString("g")
                        </div>
                    }

                    <div class="item-actions-panel stack-md">
                        <div class="item-actions-group">
                            <div class="item-actions-group-label">Save</div>

                            <button type="submit" class="btn btn-art-primary">
                                Save Return Info
                            </button>
                        </div>

                        @if (Model.IsReturnRequired || Model.IsReturned)
                        {
                            <div class="item-actions-group">
                                <div class="item-actions-group-label">Workflow</div>

                                <button type="submit"
                                        name="removeFromReturnWorkflow"
                                        value="true"
                                        class="btn btn-art-outline"
                                        onclick="return confirm('This will remove the item from the return workflow and clear return details. Continue?');">
                                    Undo Return Workflow
                                </button>
                            </div>
                        }

                        <div class="item-actions-group item-actions-group-secondary">
                            <div class="item-actions-group-label">Navigation</div>

                            <a asp-action="Details"
                            asp-route-id="@Model.Id"
                            class="btn btn-art-outline">
                                Back to Item
                            </a>
                        </div>
                    </div>

                </form>
            </section>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="form-shell">
            <section class="form-section-card">
                <h2>Current Return Receipt</h2>

                @if (hasReturnReceipt)
                {
                    <div class="stack-md">
                        @if (Model.IsReturned)
                        {
                            <span class="badge bg-danger">Returned</span>
                        }
                        else if (Model.IsReturnRequired)
                        {
                            <span class="badge bg-warning text-dark">In Return Queue</span>
                        }
                    </div>

                    @if (returnReceiptIsImage)
                    {
                        <a href="#"
                        data-bs-toggle="modal"
                        data-bs-target="#receiptPreviewModal"
                        data-receipt-src="@Model.ReturnReceiptPath"
                        data-receipt-title="@Model.Name - Return Receipt"
                        class="receipt-preview-trigger receipt-preview-large">
                            <span class="receipt-preview-surface">
                                <img src="@Model.ReturnReceiptPath"
                                    alt="Return Receipt"
                                    class="receipt-preview-image" />
                            </span>
                        </a>

                        <div class="small text-muted mt-2">
                            Click the receipt preview to enlarge it.
                        </div>
                    }
                    else 
                    {
                        <div class="receipt-preview-surface receipt-preview-large d-flex align-items-center justify-content-center text-muted small">
                            Receipt uploaded
                        </div>
                    }

                    <div class="small text-muted mt-2">
                        @Model.ReturnReceiptFileName
                        @if (Model.ReturnReceiptSizeBytes.HasValue)
                        {
                            <span>• @FileSizeHelper.FormatFileSize(Model.ReturnReceiptSizeBytes)</span>
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state-text">No return receipt uploaded.</p>
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const returnInput = document.getElementById("returnReceiptFile");
            const returnLabel = document.getElementById("returnReceiptSelectedFile");
            const returnDropZone = document.getElementById("returnReceiptDropZone");

            if (returnInput && returnLabel && returnDropZone) {
                returnDropZone.addEventListener("click", function () {
                    returnInput.click();
                });

                returnInput.addEventListener("change", function () {
                    returnLabel.textContent = this.files.length > 0
                        ? `Selected: ${this.files[0].name}`
                        : "Upload a return receipt image or PDF. Max file size: 10 MB.";
                });

                ["dragenter", "dragover"].forEach(eventName => {
                    returnDropZone.addEventListener(eventName, function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        returnDropZone.classList.add("dragover");
                    });
                });

                ["dragleave", "drop"].forEach(eventName => {
                    returnDropZone.addEventListener(eventName, function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        returnDropZone.classList.remove("dragover");
                    });
                });

                returnDropZone.addEventListener("drop", function (e) {
                    const files = e.dataTransfer.files;
                    if (files && files.length > 0) {
                        returnInput.files = files;
                        returnLabel.textContent = `Selected: ${files[0].name}`;
                    }
                });
            }
        });

    </script>
}