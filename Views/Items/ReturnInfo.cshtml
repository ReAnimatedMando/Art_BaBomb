@model Art_BaBomb.Web.Models.Item
@using Art_BaBomb.Web.Helpers

@{
    ViewData["Title"] = "Return Info";

    bool hasReturnReceipt = !string.IsNullOrWhiteSpace(Model.ReturnReceiptPath);
    bool returnReceiptIsImage =
        hasReturnReceipt &&
        (Model.ReturnReceiptPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
        || Model.ReturnReceiptPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<h1>Return Info</h1>

<div class="mb-4">
    <h4 class="mb-1">@Model.Name</h4>
    <div class="text-muted">
        Project: <strong>@Model.Project?.Name</strong>
    </div>
    <div class="text-muted">
        Item #@Model.ItemNumber
        @if (!string.IsNullOrWhiteSpace(Model.Category))
        {
            <span>• @Model.Category</span>
        }
    </div>
</div>

@if (Model.IsReturned && string.IsNullOrWhiteSpace(Model.ReturnReceiptPath))
{
    <div class="alert alert-warning fw-bold mb-4">
        This item is marked returned, but a return receipt has not been uploaded yet.
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="ReturnInfo" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProjectId" />
                    <input type="hidden" asp-for="Name" />
                    <input type="hidden" asp-for="ItemNumber" />
                    <input type="hidden" asp-for="Category" />
                    <input type="hidden" asp-for="Description" />
                    <input type="hidden" asp-for="EstimatedCost" />
                    <input type="hidden" asp-for="ActualCost" />
                    <input type="hidden" asp-for="Status" />
                    <input type="hidden" asp-for="ImageUrl" />
                    <input type="hidden" asp-for="IsReturnRequired" value="true" />

                    <div class="mb-3">
                        <label asp-for="ReturnLocation" class="form-label"></label>
                        <input asp-for="ReturnLocation" class="form-control" />
                        <span asp-validation-for="ReturnLocation" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReturnByDate" class="form-label"></label>
                        <input asp-for="ReturnByDate" class="form-control" type="date" />
                        <span asp-validation-for="ReturnByDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReturnNotes" class="form-label"></label>
                        <textarea asp-for="ReturnNotes" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="ReturnNotes" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Return Receipt</label>
                        <input type="file" name="returnReceiptFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.pdf" />
                        @Html.ValidationMessage("returnReceiptFile", new { @class = "text-danger d-block mt-1" })
                        <div class="form-text">Upload a return receipt image or PDF. Max file size: 10 MB.</div>
                    </div>

                    @if (hasReturnReceipt)
                    {
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="removeReturnReceipt"                    name="removeReturnReceipt" value="true" />
                            <label class="form-check-label" for="removeReturnReceipt">
                                Delete current return receipt
                            </label>
                        </div>
                    }

                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="IsReturned" />
                        <label class="form-check-label" asp-for="IsReturned"></label>
                    </div>

                    @if (Model.IsReturned && Model.ReturnedAt.HasValue)
                    {
                        <div class="alert alert-light border mb-4">
                            <strong>Returned At:</strong> @Model.ReturnedAt.Value.ToLocalTime().ToString("g")
                        </div>
                    }

                    <div class="d-flex gap-2 flex-wrap mt-4">
                        <button type="submit" class="btn btn-primary">Save Return Info</button>

                        @if (Model.IsReturnRequired || Model.IsReturned)
                        {
                            <button type="submit"
                                name="removeFromReturnWorkflow"
                                value="true"
                                class="btn btn-outline-secondary"
                                onclick="return confirm('This will remove the item from the return workflow and clear return details. Continue?');">
                            Undo Return Workflow
                        </button>
                        }

                        <a 
                            asp-action="Details"
                            asp-route-id="@Model.Id"
                            class="btn btn-outline-dark">
                            Back to Item
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Current Return Receipt</h5>

                @if (hasReturnReceipt)
                {
                    <div class="mb-3">
                        @if (Model.IsReturned)
                        {
                            <span class="badge bg-danger">Returned</span>
                        }
                        else if (Model.IsReturnRequired)
                        {
                            <span class="badge bg-warning text-dark">In Return Queue</span>
                        }
                    </div>

                    @if (returnReceiptIsImage)
                    {
                        <a href="@Model.ReturnReceiptPath" target="_blank">
                            <img src="@Model.ReturnReceiptPath"
                                 alt="Return Receipt"
                                 class="img-fluid rounded border mb-3" />
                        </a>
                    }

                    <div class="d-flex gap-2 flex-wrap">
                        <a href="@Model.ReturnReceiptPath" target="_blank" class="btn btn-sm btn-outline-danger">
                            View Receipt
                        </a>
                    </div>

                    <div class="small text-muted mt-2">
                        @Model.ReturnReceiptFileName
                        @if (Model.ReturnReceiptSizeBytes.HasValue)
                        {
                            <span>• @FileSizeHelper.FormatFileSize(Model.PurchaseReceiptSizeBytes)</span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No return receipt uploaded.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}